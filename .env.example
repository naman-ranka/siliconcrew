# ---------------------------------------------------------------------------
# Docker Compose host settings (optional).
# These are interpolated into docker-compose.yml (host side), NOT loaded into
# the container. `./start.sh` sets them for you; set them here only if you run
# `docker compose` directly and want to override the defaults below.
#   HOST_WORKSPACE   host dir bind-mounted to /workspace        (default ./workspace)
#   HOST_DATA_DIR    host dir bind-mounted to /root/.siliconcrew (default ./.siliconcrew_data)
#   PORT_FRONTEND / PORT_BACKEND / PORT_MCP                      (default 3000/8000/8080)
# When running compose directly, put these in a `.env` file (compose reads that
# for ${VAR} interpolation), not in .env.docker.
# HOST_WORKSPACE=./workspace
# HOST_DATA_DIR=./.siliconcrew_data

GOOGLE_API_KEY=your_google_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional default model (provider inferred from model prefix)
DEFAULT_MODEL=gemini-3.5-flash

# Codex runtime (bounded app-server warm pool is on by default).
# Set CODEX_WARM_KEEP=0 only when minimizing idle memory matters more than
# first-token latency. Defaults: at most 3 workers, retired after 15 min idle.
# CODEX_ENABLED=1
# CODEX_WARM_KEEP=1
# CODEX_WARM_MAX=3
# CODEX_WARM_IDLE_SEC=900

# Optional OpenAI fallback behavior for responses-only/strict models
# OPENAI_FORCE_FALLBACK=0
# OPENAI_FALLBACK_MODEL=gpt-5-mini

# ---------------------------------------------------------------------------
# Phase 2 platform engines (self-host leaves these unset = today's behavior).
# Set SILICONCREW_HOSTED=1 in the deployed backend to flip every seam to cloud.
# ---------------------------------------------------------------------------
# SILICONCREW_HOSTED=0
# Per-engine overrides (default to cloud under HOSTED, else local):
#   ORFS_ENGINE=local_docker|cloud_job|remote
#   SIM_ENGINE=docker|native   (xls/sby/cocotb; native = no Docker, Cloud Run safe)
#   WORKSPACE_ENGINE=local|cloud
#   PERSISTENCE_ENGINE=sqlite|postgres
#   LLM_KEY_ENGINE=env|byok
#
# Cloud wiring (only used when the corresponding engine is cloud):
# GCP_PROJECT=
# GCP_REGION=us-central1
# WORKSPACE_BUCKET=
# WORKSPACE_SCRATCH_DIR=/tmp/siliconcrew-scratch
# DATABASE_URL=postgresql+psycopg://user:pw@/siliconcrew?host=/cloudsql/<conn>
# ORFS_CLOUD_RUN_JOB=siliconcrew-orfs
# ORFS_IMAGE=us-central1-docker.pkg.dev/<proj>/siliconcrew/orfs@sha256:...
# KMS_KEY_URI=projects/<proj>/locations/<region>/keyRings/siliconcrew-byok/cryptoKeys/byok-kek
# HOSTED_GEMINI_KEY=
# HOSTED_GEMINI_MODEL=gemini-3.5-flash
# GOOGLE_OAUTH_CLIENT_ID=
# BYOK without KMS (self-host): a master key enables the EnvelopeKeyVault.
# SILICONCREW_MASTER_KEY=
# Standalone ORFS HTTP service (ORFS_ENGINE=remote):
# ORFS_SERVICE_URL=https://orfs.internal
# ORFS_SERVICE_TOKEN=
# MCP remote auth (hosted): bearer token verified into an MCP identity.
# SILICONCREW_MCP_TOKEN=
#
# Determinism: pinned ORFS P&R core count (1 = fully deterministic, slower).
# ORFS_NUM_CORES=4
# Provenance: stamp the deploying commit if not a git checkout.
# SILICONCREW_COMMIT=
